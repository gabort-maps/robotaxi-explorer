{
  "model_version": "0.3.0",
  "primary_denominator": "USD per paid vehicle-mile",
  "symbols": {
    "G": "gross_fare_per_paid_mile",
    "q": "revenue_leakage_rate",
    "R": "net_revenue_per_paid_mile",
    "u": "paid_mile_ratio",
    "C": "vehicle_av_capex",
    "rv": "residual_value_pct",
    "L": "vehicle_lifetime_miles",
    "d": "direct_running_cost_per_total_mile",
    "o": "local_fleet_ops_cost_per_total_mile",
    "V": "active_vehicles_per_city",
    "N": "number_of_cities",
    "M": "annual_total_vehicle_miles_per_vehicle",
    "PF": "annual_platform_fixed_cost",
    "PV": "platform_cost_per_vehicle_year",
    "CL": "city_launch_cost",
    "CO": "recurring_city_overhead",
    "A": "amortisation_period_years"
  },
  "derived_values": {
    "net_revenue_per_paid_mile": {
      "equation": "G × (1 − q)",
      "code_expression": "inputs.gross_fare_per_paid_mile * (1 - inputs.revenue_leakage_rate)"
    },
    "total_active_fleet": {
      "equation": "V × N",
      "code_expression": "inputs.active_vehicles_per_city * inputs.number_of_cities"
    },
    "annual_total_vehicle_miles": {
      "equation": "V × N × M",
      "code_expression": "totalActiveFleet * constants.annual_total_vehicle_miles_per_vehicle"
    },
    "annual_paid_miles": {
      "equation": "V × N × M × u",
      "code_expression": "annualTotalVehicleMiles * inputs.paid_mile_ratio"
    },
    "depreciation_per_total_mile": {
      "equation": "(C × (1 − rv)) ÷ L",
      "code_expression": "(inputs.vehicle_av_capex * (1 - inputs.residual_value_pct)) / inputs.vehicle_lifetime_miles"
    },
    "vehicle_cost_per_paid_mile": {
      "equation": "(depreciation_per_total_mile + d) ÷ u",
      "code_expression": "(depreciationPerTotalMile + inputs.direct_running_cost_per_total_mile) / inputs.paid_mile_ratio"
    },
    "local_variable_ops_per_paid_mile": {
      "equation": "o ÷ u",
      "code_expression": "inputs.local_fleet_ops_cost_per_total_mile / inputs.paid_mile_ratio"
    },
    "annual_city_burden_per_city": {
      "equation": "(CL ÷ A) + CO",
      "code_expression": "(inputs.city_launch_cost / inputs.amortisation_period_years) + inputs.recurring_city_overhead"
    },
    "city_fixed_cost_per_paid_mile": {
      "equation": "annual_city_burden_per_city ÷ (V × M × u)",
      "code_expression": "annualCityBurdenPerCity / (inputs.active_vehicles_per_city * constants.annual_total_vehicle_miles_per_vehicle * inputs.paid_mile_ratio)"
    },
    "annual_platform_burden": {
      "equation": "PF + (PV × V × N)",
      "code_expression": "inputs.annual_platform_fixed_cost + (inputs.platform_cost_per_vehicle_year * totalActiveFleet)"
    }
  },
  "primary_outputs": {
    "direct_cost_per_paid_mile": {
      "definition": "Vehicle, direct running, local variable operations and annualised city burden, before central platform cost.",
      "equation": "vehicle_cost_per_paid_mile + local_variable_ops_per_paid_mile + city_fixed_cost_per_paid_mile",
      "code_expression": "vehicleCostPerPaidMile + localVariableOpsPerPaidMile + cityFixedCostPerPaidMile"
    },
    "city_contribution_per_paid_mile": {
      "definition": "Net revenue remaining after all vehicle and local city costs.",
      "equation": "R − direct_cost_per_paid_mile",
      "code_expression": "netRevenuePerPaidMile - directCostPerPaidMile"
    },
    "platform_cost_per_paid_mile": {
      "definition": "Annual fixed platform burden plus per-vehicle platform burden allocated across annual paid miles.",
      "equation": "(PF + PV × V × N) ÷ (V × N × M × u)",
      "code_expression": "annualPlatformBurden / annualPaidMiles"
    },
    "enterprise_result_per_paid_mile": {
      "definition": "City contribution after central platform cost.",
      "equation": "city_contribution_per_paid_mile − platform_cost_per_paid_mile",
      "code_expression": "cityContributionPerPaidMile - platformCostPerPaidMile"
    },
    "break_even_gap_per_paid_mile": {
      "definition": "Additional contribution required to reach zero enterprise result.",
      "equation": "max(0, −enterprise_result_per_paid_mile)",
      "code_expression": "Math.max(0, -enterpriseResultPerPaidMile)"
    },
    "break_even_solutions": {
      "definition": "For each enabled main variable, hold all other inputs constant and solve enterprise_result_per_paid_mile = 0 within that architecture's credible low-high range.",
      "algorithm": "bounded bisection",
      "tolerance": 1e-07,
      "max_iterations": 100,
      "achievable_rule": "A solution is achievable only if the result equals zero at a boundary or changes sign across the credible low-high range.",
      "non_achievable_message": "Not achievable within the evidence-based range."
    }
  },
  "sankey_flows": [
    {
      "source": "Gross fare",
      "target": "Revenue leakage",
      "value_expression": "inputs.gross_fare_per_paid_mile * inputs.revenue_leakage_rate"
    },
    {
      "source": "Gross fare",
      "target": "Net revenue",
      "value_expression": "netRevenuePerPaidMile"
    },
    {
      "source": "Net revenue",
      "target": "Vehicle and engineering",
      "value_expression": "vehicleCostPerPaidMile"
    },
    {
      "source": "Net revenue",
      "target": "Local fleet operations",
      "value_expression": "localVariableOpsPerPaidMile + cityFixedCostPerPaidMile"
    },
    {
      "source": "Net revenue",
      "target": "City contribution",
      "value_expression": "Math.max(0, cityContributionPerPaidMile)"
    },
    {
      "source": "City contribution",
      "target": "Platform and replication",
      "value_expression": "Math.min(Math.max(0, cityContributionPerPaidMile), platformCostPerPaidMile)"
    },
    {
      "source": "External funding",
      "target": "Platform and replication",
      "value_expression": "Math.max(0, -enterpriseResultPerPaidMile)"
    },
    {
      "source": "City contribution",
      "target": "Enterprise surplus",
      "value_expression": "Math.max(0, enterpriseResultPerPaidMile)"
    }
  ],
  "tornado_methodology": {
    "baseline_metric": "enterprise_result_per_paid_mile",
    "variables": "All main and advanced variables exposed for the selected architecture",
    "low_case": "Set one variable to that architecture's range.low while holding all others at the current scenario value.",
    "high_case": "Set one variable to that architecture's range.high while holding all others at the current scenario value.",
    "impact_low": "enterpriseResultAtLow - baselineEnterpriseResult",
    "impact_high": "enterpriseResultAtHigh - baselineEnterpriseResult",
    "sorting": "Descending by max(abs(impact_low), abs(impact_high))",
    "confidence_display": "Separate HTML confidence column or badge, not colour alone.",
    "methodology_note": "Range widths reflect the evidence base and genuine uncertainty. They are not normalised to make variables appear equally important."
  },
  "methodology_notes": {
    "architecture_vs_maturity": "Architecture and maturity are separate dimensions because combining a Tesla vehicle-cost assumption with Waymo-shaped operating, platform and city-launch assumptions produces an incoherent hybrid. v0.3 separates Waymo current, Waymo next-gen and Cybercab so observed-proxy and forward-looking evidence are not blended.",
    "evidence_quality": "Presets carry an evidence_quality tag so users can distinguish observed_proxy, stress_legacy, forward_looking and claims_realised scenarios at the surface level.",
    "energy_in_direct_running_cost": "Energy efficiency is folded into direct running cost rather than exposed as a separate slider because the public interface focuses on the highest-leverage profitability levers. Architecture-specific energy evidence is reflected in the direct-running-cost defaults and ranges.",
    "waymo_city_and_fleet_basis": "The Waymo-current default uses 11 current rider-service markets and 300 active-fleet-equivalent vehicles per city. The city count is directly observed. The vehicle-density default is triangulated from Waymo's reported weekly mileage and the model's annual-mileage assumption.",
    "platform_split": "v0.3 splits annual platform burden into fixed/reusable platform cost and per-vehicle platform cost. Platform leverage applies only to the fixed/reusable portion.",
    "city_cost_split": "v0.3 splits city cost into one-time launch cost and recurring city overhead. The annual city burden is city_launch_cost divided by amortisation_period_years plus recurring_city_overhead."
  },
